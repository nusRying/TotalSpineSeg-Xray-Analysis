# =============================================================================
# TotalSpineSeg X-Ray Analysis — .gitignore
# =============================================================================

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Testing
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Environments
.env
.env.*
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Jupyter
.ipynb_checkpoints

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
.pdm.toml
__pypackages__/

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# Rope / Spyder
.ropeproject
.spyderproject
.spyproject

# mkdocs
/site

# PyCharm — uncomment below only if all devs use JetBrains
# .idea/

# =============================================================================
# MACHINE LEARNING / NNUNET
# =============================================================================

# nnUNet model weights (large binary files — download separately)
*.pth
*.pkl

# NIfTI medical imaging files (raw data — too large for git)
*.nii.gz
*.nii

# DICOM files (patient data — never commit to git)
*.dcm
*.dicom
*.DCM

# =============================================================================
# PROJECT DATA — Never commit training data to git
# =============================================================================

# All data (raw images, masks, nnUNet datasets, results)
data/

# Deliverable packages (client-facing output — too large)
deliverables/
milestone3_delivery/

# Training logs (generated at runtime)
logs/

# Scratch / temporary experiment outputs
scratch/
tmp/
temp/

# Comparison images generated locally
comparison_*.png
*_comparison.png

# =============================================================================
# SECRETS & CREDENTIALS — Never commit
# =============================================================================
secrets.json
credentials.json
*.pem
*.key
*.p12
*.pfx
.env
.env.*
!.env.example

# =============================================================================
# TEMPORARY & BACKUP FILES
# =============================================================================
*.bak
*.tmp
*.temp
*.swp
*.swo
~$*
*~
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# ARCHIVES (usually large; download separately)
# =============================================================================
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# =============================================================================
# OS
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~

# =============================================================================
# EDITORS
# =============================================================================
# VS Code (keep settings committed for team consistency)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains
.idea/

# Vim / Emacs
*.vim
\#*\#
/.emacs.d
*.elc

# =============================================================================
# EXPLICITLY ALLOW — These must pass through even if a parent is ignored
# =============================================================================

# All docs are ALWAYS committed
!docs/
!docs/**
!docs/*.md
!docs/*.pdf
!docs/client_materials/
!docs/client_materials/**

# Key result files for reporting
!dice_distribution.png
!metrics_summary.json
!sample_result_1.png
!sample_result_2.png
!per_case_metrics.csv

# Requirements
!requirements.txt
!requirements-xray.txt

# Example env file (no real secrets)
!.env.example
